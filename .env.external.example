# xcn-similarity app settings when MongoDB/Milvus are owned by xcn-similarity-infra.

SIM_IMAGE_REPO=xcn-similarity
SIM_IMAGE_TAG=0.1.0
KAFKA_IMAGE=xcn-similarity/kafka:latest
COMPOSE_PROFILES=

SIM_PRODUCT_MODE=standalone
SIM_ADMIN_UI_ENABLED=false
SIM_SECURITY_INSIGHT_ENABLED=auto
SIM_LLM_ENABLED=false
SIM_LLM_URL=
SIM_LLM_MODEL=qwen3.5-27b-fp8
SIM_LLM_TIMEOUT_SEC=60
SIM_MANUAL_REVIEW_ENABLED=auto
SIM_RECENT_MATCH_CACHE_ENABLED=auto

# Infra endpoints. Use the infra host address rather than docker service names.
SIM_CATALOG_MONGO_URI=mongodb://10.100.40.52:27017/xcn_similarity?serverSelectionTimeoutMS=5000&connectTimeoutMS=10000
SIM_MILVUS_URL=http://10.100.40.52:19530

# If app and infra remain on the same server, keep the Milvus internal MinIO volume mounted read-only.
# If infra moves to another host, this physical storage stat path needs a shared mount or code change.
SIM_MILVUS_MINIO_VOLUME=/data01/xcn-similarity-infra/data/minio
SIM_MILVUS_OBJECT_ROOT=/minio_data/a-bucket/files
SIM_MONITOR_PATHS=/,/logs,/minio_data

SIM_CATALOG_DATABASE=xcn_similarity
SIM_LOG_CATALOG_COLLECTION=SIM_LOG_CATALOG
SIM_DOCUMENT_CATALOG_COLLECTION=SIM_DOCUMENT_CATALOG
SIM_REVIEW_COLLECTION=SIM_MATCH_REVIEW
SIM_MATCH_CACHE_COLLECTION=SIM_MATCH_CACHE
SIM_INDEXER_STATE_COLLECTION=SIM_INDEXER_STATE
SIM_INDEXER_FAILED_COLLECTION=SIM_INDEXER_FAILED

SIM_EMBEDDER_BACKEND=hf_transformer
SIM_EMBEDDING_DIM=1024
SIM_EMBEDDING_MODEL_PATH=/models/upskyy_bge_m3_korean
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

SIM_CHUNK_SIZE=1800
SIM_CHUNK_OVERLAP=250
SIM_MIN_CHUNK_CHARS=50
SIM_MAX_DOCUMENT_CHUNKS=5000
SIM_MAX_LOG_CHUNKS=100
SIM_MAX_UPLOAD_MB=300
SIM_MULTI_UPLOAD_MAX_FILES=50
SIM_ARCHIVE_MAX_FILES=500
SIM_ARCHIVE_MAX_TOTAL_MB=1024
SIM_ARCHIVE_MAX_MEMBER_MB=100
SIM_UPLOAD_DIR=/logs/uploads

SIM_RECENT_MATCH_MIN_SCORE=0.82
SIM_RECENT_MATCH_LOG_LIMIT=50
SIM_RECENT_MATCH_LIMIT=20
SIM_RECENT_MATCH_DAYS=30
SIM_RECENT_MATCH_CACHE_TTL_SEC=1800
SIM_RECENT_MATCH_INCLUDE_DEFAULT_PARTITION=true
SIM_SIMILARITY_RESULT_SEARCH_RETRIES=5
SIM_SIMILARITY_RESULT_SEARCH_RETRY_DELAY_SEC=0.5
SIM_SIMILARITY_RESULT_RECENT_DOCUMENT_WINDOW_SEC=30

SIM_KAFKA_ENABLED=false
SIM_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
SIM_KAFKA_TOPIC=analysis_result
SIM_KAFKA_CLIENT_ID=xcn-similarity
SIM_KAFKA_TIMEOUT_SEC=5

# EMS source data. This is external source infra, not xcn-similarity-infra.
EMS_MONGO_URI=mongodb://10.10.20.6:27018/venus?replicaSet=shard1rs&readPreference=primary&serverSelectionTimeoutMS=5000&connectTimeoutMS=10000&directConnection=true
MINIO_ENDPOINT=http://10.10.20.6:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

EMS_INDEX_MONTHS=auto_recent
EMS_INDEX_MONTHS_LOOKBACK=2
EMS_INDEX_INTERVAL_SEC=60
EMS_INDEX_BATCH_SIZE=500
EMS_INDEX_POST_BATCH_SIZE=50
EMS_INDEX_POST_RETRIES=5
EMS_INDEX_POST_RETRY_DELAY_SEC=5
EMS_INDEX_CURSOR_FIELD=ltime
EMS_INDEX_TIMEZONE=Asia/Seoul
EMS_INDEX_ENSURE_SOURCE_INDEXES=true
EMS_INDEX_BODY=true
EMS_INDEX_ATTACH=true
EMS_INDEX_EXCLUDE_SVC=FGIS
EMS_INDEX_EXCLUDE_SVC_PREFIX=FGI
EMS_INDEX_SEED_MISSING_RECENT=true

HF_HOME=/data/hf
SENTENCE_TRANSFORMERS_HOME=/data/hf/sentence_transformers

# Image tags
SIM_IMAGE_REPO=xcn-similarity
SIM_IMAGE_TAG=1.0.0
KAFKA_IMAGE=xcn-similarity/kafka:latest

# Optional services
# Empty value starts the default API stack only. Set to indexer to include EMS indexing.
COMPOSE_PROFILES=

# Runtime
TZ=Asia/Seoul
UVICORN_WORKERS=1
SIM_LOG_LEVEL=INFO
SIM_FILE_LOG_ENABLED=true
SIM_LOG_DIR=/logs
SIM_LOG_ROTATE_WHEN=midnight
SIM_LOG_BACKUP_DAYS=30
SIM_LOG_BACKUP_COUNT=30
SIM_LOG_MAX_BYTES=0

# Product mode and optional features
# standalone: local result storage only. integrated: external integration profile. ops: enables UI/ops defaults.
SIM_PRODUCT_MODE=standalone
SIM_ADMIN_UI_ENABLED=false
SIM_SECURITY_INSIGHT_ENABLED=auto
SIM_LLM_ENABLED=false
SIM_LLM_URL=
SIM_LLM_MODEL=qwen3.5-27b-fp8
SIM_LLM_TIMEOUT_SEC=60
SIM_MANUAL_REVIEW_ENABLED=auto
SIM_RECENT_MATCH_CACHE_ENABLED=auto

# Similarity engine
# 1st split default: use Milvus from docker-compose.infra.yml on the shared compose network.
# 2nd externalization: set this to the external Milvus endpoint, for example http://10.100.40.xx:19530.
SIM_MILVUS_URL=http://milvus:19530
# Local infra mode keeps the Milvus MinIO volume mounted into the API for storage stats.
# If Milvus is moved to another host, this path is no longer locally readable unless the object
# storage volume is also mounted on the API host.
SIM_MILVUS_MINIO_VOLUME=/data01/xcn-similarity-infra/data/minio
SIM_MILVUS_OBJECT_ROOT=/minio_data/a-bucket/files
SIM_STORAGE_STATS_TTL_SEC=300
SIM_EMBEDDER_BACKEND=hf_transformer
SIM_EMBEDDING_DIM=1024
SIM_EMBEDDING_MODEL_PATH=/models/upskyy_bge_m3_korean

# Chunking and limits
SIM_CHUNK_SIZE=1800
SIM_CHUNK_OVERLAP=250
SIM_MIN_CHUNK_CHARS=50
SIM_MAX_DOCUMENT_CHUNKS=5000
SIM_MAX_LOG_CHUNKS=100
SIM_MAX_MIDDLEWARE_CHUNKS=100
SIM_MAX_MIDDLEWARE_CHARS=2000000
SIM_MAX_MIDDLEWARE_ITEM_CHARS=800000
SIM_MAX_UPLOAD_MB=300
SIM_MULTI_UPLOAD_MAX_FILES=50
SIM_ARCHIVE_MAX_FILES=500
SIM_ARCHIVE_MAX_TOTAL_MB=1024
SIM_ARCHIVE_MAX_MEMBER_MB=100
SIM_UPLOAD_DIR=/logs/uploads
SIM_UPLOAD_RETAIN_ORIGINAL=true
SIM_UPLOAD_DELETED_RETENTION_DAYS=0
SIM_SEARCH_UPLOAD_RETENTION_DAYS=7
SIM_RECENT_MATCH_MIN_SCORE=0.82
SIM_RECENT_MATCH_LOG_LIMIT=50
SIM_RECENT_MATCH_LIMIT=20
SIM_RECENT_MATCH_DAYS=30
SIM_RECENT_MATCH_CACHE_TTL_SEC=1800
SIM_RECENT_MATCH_INCLUDE_DEFAULT_PARTITION=true
SIM_SEARCH_LOGS_DEFAULT_DAYS=30
SIM_SEARCH_LOGS_MAX_DOCUMENT_CHUNKS=8
SIM_SEARCH_LOGS_PARALLELISM=4
SIM_SEARCH_LOGS_CACHE_ENABLED=true
SIM_SEARCH_LOGS_CACHE_TTL_SEC=300
SIM_SEARCH_LOGS_INCLUDE_DEFAULT_PARTITION=true
SIM_SIMILARITY_RESULT_SEARCH_RETRIES=5
SIM_SIMILARITY_RESULT_SEARCH_RETRY_DELAY_SEC=0.5
SIM_SIMILARITY_RESULT_RECENT_DOCUMENT_WINDOW_SEC=30
# Optional fallback cutoff for POST /similarity/logs/delete-by-retention.
# Default operation keeps logging embeddings for 365 days regardless of service type.
SIM_LOG_DELETE_BEFORE_DAYS=365
SIM_LOG_RETENTION_SVC=
# Log retention policy used by cleanup worker. Use *=365 for all service types.
SIM_LOG_RETENTION_POLICY=*=365
# Linked cleanup for data generated from deleted log msgids. Results are safe to delete by msgid.
SIM_LOG_RETENTION_DELETE_RESULTS=true
# Reviews and match cache are conservative by default. Enable only after operating policy is confirmed.
SIM_LOG_RETENTION_DELETE_REVIEWS=false
SIM_LOG_RETENTION_CLEAR_MATCH_CACHE=false
SIM_CLEANUP_ENABLED=true
SIM_CLEANUP_INTERVAL_SEC=86400
SIM_CLEANUP_DRY_RUN=false
SIM_RESULT_RETENTION_DAYS=0
SIM_MATCH_CACHE_RETENTION_DAYS=7
SIM_REVIEW_RETENTION_DAYS=0

# Catalog DB for production operation
# 1st split default: use MongoDB from docker-compose.infra.yml on the shared compose network.
# 2nd externalization: set this to the external catalog MongoDB URI.
SIM_CATALOG_MONGO_URI=mongodb://mongodb:27017/xcn_similarity?serverSelectionTimeoutMS=5000&connectTimeoutMS=10000
SIM_CATALOG_DATABASE=xcn_similarity
SIM_LOG_CATALOG_COLLECTION=SIM_LOG_CATALOG
SIM_DOCUMENT_CATALOG_COLLECTION=SIM_DOCUMENT_CATALOG
SIM_REVIEW_COLLECTION=SIM_MATCH_REVIEW
SIM_MATCH_CACHE_COLLECTION=SIM_MATCH_CACHE
SIM_INDEXER_STATE_COLLECTION=SIM_INDEXER_STATE
SIM_INDEXER_FAILED_COLLECTION=SIM_INDEXER_FAILED

# Similarity result delivery
# Standalone product leaves Kafka disabled. For integrated delivery, set true and run compose with profile kafka if using bundled Kafka.
SIM_KAFKA_ENABLED=false
SIM_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
SIM_KAFKA_TOPIC=analysis_result
SIM_KAFKA_CLIENT_ID=xcn-similarity
SIM_KAFKA_TIMEOUT_SEC=5
# Middleware only triggers one-message analysis and receives the result.
SIM_MIDDLEWARE_BASE_URL=
SIM_MIDDLEWARE_RESULT_PATH=/similarity/result
SIM_MIDDLEWARE_TIMEOUT_SEC=60

# EMS incremental indexer
# Middleware ingest is the primary production flow. Keep direct source indexing disabled unless explicitly needed.
EMS_INDEX_DIRECT_ENABLED=false
# API still reads the requested one-message source data directly from EMS MongoDB/MinIO.
EMS_MONGO_URI=mongodb://mongodb:27017/venus?serverSelectionTimeoutMS=5000&connectTimeoutMS=10000
EMS_INDEX_MONTHS=auto_recent
EMS_INDEX_MONTHS_LOOKBACK=2
EMS_INDEX_INTERVAL_SEC=60
EMS_INDEX_BATCH_SIZE=500
EMS_INDEX_POST_BATCH_SIZE=50
EMS_INDEX_POST_RETRIES=5
EMS_INDEX_POST_RETRY_DELAY_SEC=5
EMS_INDEX_CURSOR_FIELD=ltime
EMS_INDEX_TIMEZONE=Asia/Seoul
EMS_INDEX_ENSURE_SOURCE_INDEXES=true
EMS_INDEX_BODY=true
EMS_INDEX_ATTACH=true
EMS_INDEX_EXCLUDE_SVC=FGIS
EMS_INDEX_EXCLUDE_SVC_PREFIX=FGI
EMS_INDEX_SEED_MISSING_RECENT=true
# EMS attachment MinIO endpoint. This is not the Milvus internal MinIO unless explicitly testing locally.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Offline model paths
HF_HOME=/data/hf
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
SENTENCE_TRANSFORMERS_HOME=/data/hf/sentence_transformers
